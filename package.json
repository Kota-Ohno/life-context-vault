{
  "name": "life-context-vault",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "node scripts/run-tauri-with-sidecars.mjs build --no-bundle",
    "tauri:bundle": "node scripts/run-tauri-with-sidecars.mjs build --bundles app",
    "sidecars:prepare": "node scripts/prepare-tauri-sidecars.mjs",
    "mcp:build": "cargo build --release --manifest-path src-tauri/Cargo.toml --bin lcv-mcp",
    "mcp:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin lcv-mcp",
    "retrieval:bench": "cargo test --release --manifest-path src-tauri/Cargo.toml large_scale_retrieval_benchmark_100k_facts_500k_chunks -- --ignored --nocapture",
    "product:check": "node scripts/run-product-release-checks.mjs",
    "product:check:full": "node scripts/run-product-release-checks.mjs --full"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@tauri-apps/plugin-notification": "^2.3.3",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.0.15"
  }
}
