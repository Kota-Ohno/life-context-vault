{
  "name": "life-context-vault-poc",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --no-bundle",
    "tauri:bundle": "tauri build --bundles app",
    "mcp:build": "cargo build --release --manifest-path src-tauri/Cargo.toml --bin lcv-mcp",
    "mcp:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin lcv-mcp",
    "relay:build": "cargo build --release --manifest-path src-tauri/Cargo.toml --bin lcv-relay",
    "relay:dev": "cargo run --manifest-path src-tauri/Cargo.toml --bin lcv-relay"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.11.0",
    "@vitejs/plugin-react": "^5.1.1",
    "lucide-react": "^0.561.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.7"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.11.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "vitest": "^4.0.15"
  }
}
